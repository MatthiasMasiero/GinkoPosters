# Database
# Railway Postgres plugin auto-provides DATABASE_URL in postgresql:// format.
# The backend auto-converts it to asyncpg format. DATABASE_URL_SYNC is optional.
DATABASE_URL=postgresql+asyncpg://ginko:ginko_dev@localhost:5432/ginkoposters
DATABASE_URL_SYNC=postgresql://ginko:ginko_dev@localhost:5432/ginkoposters

# Stripe
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# JWT
JWT_SECRET_KEY=change-this-in-production-use-a-long-random-string

# AWS S3
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=eu-central-1
S3_BUCKET_NAME=ginkoposters-print-files

# Resend (email)
RESEND_API_KEY=re_placeholder
FROM_EMAIL=Ginko Posters <noreply@ginkoposters.com>

# App
PRIMARY_DOMAIN=localhost
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
